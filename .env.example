# ─────────────────────────────────────────────────────────────────────────────
# Atrovia.co — Vercel environment variables
# Copy this file to .env.local for local dev.
# Add the SAME keys in Vercel → Project → Settings → Environment Variables.
# NEVER commit real values — .env and .env.local are in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# Public site URL (used for Stripe success/cancel redirect URLs)
# Local:  http://localhost:3000
# Prod:   https://atrovia.co
NEXT_PUBLIC_SITE_URL=https://atrovia.co

# ── Stripe ───────────────────────────────────────────────────────────────────
# Secret key — Stripe Dashboard → Developers → API keys
# TEST:  sk_test_...
# LIVE:  sk_live_...  (only after you've tested end-to-end in test mode)
STRIPE_SECRET_KEY=sk_test_xxx

# Webhook signing secret — created when you register the webhook endpoint:
#   Stripe Dashboard → Developers → Webhooks → Add endpoint
#   URL: https://atrovia.co/api/webhook
#   Events to listen for: checkout.session.completed
# OR use `stripe listen --forward-to localhost:3000/api/webhook` for local dev
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Recurring Price IDs — Stripe Dashboard → Products → each product → Pricing
# Create three monthly recurring prices and paste the "API ID" (price_...) here
STRIPE_PRICE_ATRIUM=price_xxx
STRIPE_PRICE_KOVA=price_xxx
STRIPE_PRICE_BOTH=price_xxx

# ── Resend (email) ────────────────────────────────────────────────────────────
# API key — resend.com → API Keys
# Verify atrovia.co domain in Resend to send from @atrovia.co addresses.
# Until verified, use the default onboarding@resend.dev sender.
RESEND_API_KEY=re_xxx

# The "From" address customers see on the welcome email
EMAIL_FROM=Atrovia <welcome@atrovia.co>

# Internal address that receives a notification on every paid signup
INTERNAL_NOTIFY_EMAIL=Info@atrovia.co

# ── Provisioning hook (optional) ─────────────────────────────────────────────
# When set, the Stripe webhook POSTs customer data here to activate
# Atrovia / Atrium / Kova access in your product backend.
# Leave blank to skip — emails still send.
PROVISION_WEBHOOK_URL=
PROVISION_WEBHOOK_SECRET=
