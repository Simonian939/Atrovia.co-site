{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/beta", "destination": "/signup" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    }
  ]
}
